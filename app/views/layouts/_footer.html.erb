<footer class="bg-white border-t border-gray-200 mt-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-start">

      <!-- Logo + Tagline -->
      <div>
        <h2 class="text-2xl font-bold text-pink-500 tracking-tight">
          Bermet Talantbekova  <span class="text-gray-900">Rails</span>
        </h2>

        <p class="mt-2 text-sm text-gray-500 max-w-xs">
          A better way to share your audio books, thoughts, and podcasts - powered by Ruby on Rails.
        </p>
      </div>

      <!-- Navigation Links -->
      <div class="flex flex-col space-y-2 text-sm font-medium text-gray-600">
        <%= link_to "Audiobooks", posts_path, class: "hover:text-purple-600 transition" %>
        <%= link_to "Podcasts", audiobooks_path, class: "hover:text-purple-600 transition" %>
        <%#= link_to "About", about_path, class: "hover:text-purple-600 transition" %>
      </div>

    </div>

    <!-- Bottom Bar -->
    <div class="mt-10 border-t pt-6 text-sm text-gray-400 text-center">
      &copy; <%= Time.now.year %> Bermet's AudioBook Shelf By Bermet Talantbekova 
    </div>

  </div>
</footer>