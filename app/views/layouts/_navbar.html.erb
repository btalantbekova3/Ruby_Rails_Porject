<header class="bg-white shadow-md sticky top-0 z-50">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <div class="flex-shrink-0">
       <%= link_to root_path, class: "text-2xl sm:text-3xl font-bold text-gray-900 tracking-tight 
        hover:text-blue-600 transition" do %> Bermet Talantbekova <span class="text-pink-600">Rails</span>
       <% end %>
      </div>


    <div class="hidden md:flex flex-1 justify-center items-center space-x-6">
      <%= link_to "Audiobooks", posts_path, class: "text-gray-700 hover:text-blue-600 font-medium transition" %>
      <%= link_to "Podcasts", audiobooks_path, class: "text-gray-700 hover:text-blue-600 font-medium transition" %>
      
    </div>


<div class="relative w-64 hidden lg:block">
      <%= form_with url: posts_path,
              method: :get,
              local: true,
              data: {
                search_delay_value: 300,
                controller: "search",
                turbo_frame: "posts"
              },
              class: "w-full relative" do |f| %>

  <%= f.text_field :query,
      value: params[:query],
      placeholder: "Quick Search...",
      autocomplete: "off",
      data: { action: "input->search#submit" },
      class: "w-full py-2 px-4 pr-10 rounded-full border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:outline-none transition text-sm placeholder-gray-500" %>

  <!-- Search icon -->
  <svg class="absolute right-3 top-2.5 h-5 w-5 text-gray-400 pointer-events-none"
       xmlns="http://www.w3.org/2000/svg"
       fill="none"
       viewBox="0 0 24 24"
       stroke="currentColor">

    <path stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M21 21l-4.35-4.35M11 18a7 7 0 100-14 7 7 0 000 14z" />
  </svg>
  <% end %>
  <turbo-frame id="search_results"  class="absolute z-50 bg-white shadow-lg rounded-md w-full mt-1 max-h-72 overflow-y-auto"></
  turbo-frame>
</div>


</div>
  </nav>
</header>